{
  "name": "neotolis-game-promotion-diary",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.11",
    "pnpm": ">=9"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "vite dev",
    "build": "vite build",
    "preview": "vite preview",
    "typecheck": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "lint": "svelte-kit sync && eslint . && prettier --check .",
    "format": "prettier --write .",
    "test": "svelte-kit sync && vitest run",
    "test:unit": "svelte-kit sync && vitest run tests/unit",
    "test:integration": "svelte-kit sync && vitest run tests/integration",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/lib/server/db/migrate.ts",
    "db:check": "drizzle-kit check",
    "start": "node build/server.js"
  },
  "dependencies": {
    "hono": "4.12.15",
    "@hono/node-server": "1.19.14",
    "@hono/zod-validator": "^0.4.0",
    "drizzle-orm": "0.45.2",
    "pg": "8.20.0",
    "pg-boss": "10.4.2",
    "better-auth": "1.6.9",
    "pino": "^9.5.0",
    "zod": "^3.23.8",
    "@inlang/paraglide-js": "2.16.1",
    "@sveltejs/kit": "^2.58.0",
    "@sveltejs/adapter-node": "^5.2.0",
    "@sveltejs/vite-plugin-svelte": "^7.0.0",
    "svelte": "^5.55.5",
    "vite": "^8.0.0",
    "ipaddr.js": "^2.2.0",
    "uuidv7": "^1.0.2",
    "rate-limiter-flexible": "^5.0.0",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "drizzle-kit": "^0.31.0",
    "vitest": "^4.1.5",
    "@vitest/coverage-v8": "^4.1.5",
    "oauth2-mock-server": "^7.2.0",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.0",
    "eslint": "^9.13.0",
    "@eslint/js": "^9.13.0",
    "@typescript-eslint/parser": "^8.12.0",
    "@typescript-eslint/eslint-plugin": "^8.12.0",
    "eslint-plugin-svelte": "^2.46.0",
    "svelte-eslint-parser": "^0.43.0",
    "eslint-config-prettier": "^9.1.0",
    "globals": "^15.0.0",
    "prettier": "^3.3.3",
    "prettier-plugin-svelte": "^3.2.7",
    "svelte-check": "^4.0.0",
    "pino-pretty": "^11.3.0"
  }
}
