# Phase 1 Foundation environment variables
# Copy to .env for local dev; never commit .env

# Required
DATABASE_URL=postgres://postgres:postgres@localhost:5432/neotolis
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_SECRET=replace-with-32-char-random-hex-or-longer-please
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret
APP_KEK_BASE64=base64-encoded-32-bytes-here  # generate with: openssl rand -base64 32

# Optional (defaults shown)
NODE_ENV=development
APP_ROLE=app                    # app | worker | scheduler
APP_MODE=selfhost               # saas | selfhost
PORT=3000
LOG_LEVEL=info                  # debug | info | warn | error
TRUSTED_ORIGINS=                # CSV of allowed CORS origins
TRUSTED_PROXY_CIDR=             # CSV of trusted proxy CIDRs (D-20: empty = trust nothing)
COOKIE_DOMAIN=                  # optional; needed only for SaaS subdomain cookies
KEK_CURRENT_VERSION=1
# APP_KEK_V2_BASE64=...         # add during KEK rotation; remove APP_KEK_BASE64 only after re-wrap
